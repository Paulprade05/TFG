<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="Optima.db" readonly="0" foreign_keys="0" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="0"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="3583"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="sqlite_sequence" custom_title="0" dock_id="1" table="4,15:mainsqlite_sequence"/><dock_state state="000000ff00000000fd00000001000000020000000000000000fc0100000001fb000000160064006f0063006b00420072006f00770073006500310100000000ffffffff0000011e00ffffff000000000000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings/></tab_browse><tab_sql><sql name="SQL 1*">-- 1. Cabecera de Facturas de Venta
-- Actualizada para referenciar al Albarán (Trazabilidad)
CREATE TABLE IF NOT EXISTS &quot;FacturasVenta&quot; (
	&quot;ID_FacturaVenta&quot;	INTEGER PRIMARY KEY AUTOINCREMENT,
	&quot;NumeroFactura&quot;	TEXT UNIQUE NOT NULL,
	&quot;Fecha&quot;	DATE DEFAULT CURRENT_DATE,
	&quot;ID_Cliente&quot;	INTEGER NOT NULL,
	&quot;ID_Albaran&quot;	INTEGER, -- Trazabilidad: De qué albarán proviene
	&quot;BaseImponible&quot;	REAL DEFAULT 0,
	&quot;ImporteIVA&quot;	REAL DEFAULT 0,
	&quot;TotalFactura&quot;	REAL DEFAULT 0,
	&quot;Cobrada&quot;	INTEGER DEFAULT 0, -- 0: Pendiente, 1: Cobrada
	FOREIGN KEY(&quot;ID_Cliente&quot;) REFERENCES &quot;Clientes&quot;(&quot;ID_Cliente&quot;),
	FOREIGN KEY(&quot;ID_Albaran&quot;) REFERENCES &quot;Albaranes&quot;(&quot;ID_Albaran&quot;)
);

-- 2. Líneas de Factura de Venta
CREATE TABLE IF NOT EXISTS &quot;LineasFacturaVenta&quot; (
	&quot;ID_LineaFactura&quot;	INTEGER PRIMARY KEY AUTOINCREMENT,
	&quot;ID_FacturaVenta&quot;	INTEGER NOT NULL,
	&quot;NumeroOrden&quot;	INTEGER, -- Campo solicitado para ordenación
	&quot;ID_Articulo&quot;	INTEGER,
	&quot;Descripcion&quot;	TEXT,
	&quot;Cantidad&quot;	REAL DEFAULT 1,
	&quot;PrecioUnitario&quot;	REAL DEFAULT 0,
	&quot;Descuento&quot;	REAL DEFAULT 0,
	FOREIGN KEY(&quot;ID_FacturaVenta&quot;) REFERENCES &quot;FacturasVenta&quot;(&quot;ID_FacturaVenta&quot;) ON DELETE CASCADE,
	FOREIGN KEY(&quot;ID_Articulo&quot;) REFERENCES &quot;Articulos&quot;(&quot;ID_Articulo&quot;)
);</sql><current_tab id="0"/></tab_sql></sqlb_project>
